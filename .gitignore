# Ignore everything by default
*

# Keep repository control files
!.gitignore
!README.md

# Keep Docker compose file (both common spellings)
!docker-compose.yml
!docker-compose.yaml

# Ignore SQL dumps by default, except the canonical project backup
*.sql
!wp-content/raiz_backup.sql
!wp-content/raiz_v1_servicios_ready.sql

# Keep only the custom theme under wp-content
!wp-content/
wp-content/*
!wp-content/raiz_backup.sql
!wp-content/raiz_v1_servicios_ready.sql
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/raiz-v1/
!wp-content/themes/raiz-v1/**
{
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "base", "color": "#F2E8DC", "name": "Fond (Sable)" },
        { "slug": "contrast", "color": "#590902", "name": "Titres (Profond)" },
        { "slug": "primary", "color": "#8C3623", "name": "Primaire (Terre)" },
        { "slug": "secondary", "color": "#BF9180", "name": "Secondaire (Doux)" },
        { "slug": "tertiary", "color": "#8C2E26", "name": "Accent (Brique)" }
      ]
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true,
      "spacingSizes": [
        {
          "name": "Espacement 10",
          "size": "clamp(0.5rem, 0.45rem + 0.25vw, 0.75rem)",
          "slug": "10"
        },
        {
          "name": "Espacement 20",
          "size": "clamp(0.75rem, 0.7rem + 0.3vw, 1rem)",
          "slug": "20"
        },
        {
          "name": "Espacement 30",
          "size": "clamp(1rem, 0.9rem + 0.5vw, 1.5rem)",
          "slug": "30"
        },
        {
          "name": "Espacement 40",
          "size": "clamp(1.5rem, 1.2rem + 1vw, 2rem)",
          "slug": "40"
        },
        {
          "name": "Espacement 50",
          "size": "clamp(2rem, 1.5rem + 1.5vw, 3rem)",
          "slug": "50"
        },
        {
          "name": "Espacement 60",
          "size": "clamp(3rem, 2.4rem + 2vw, 4rem)",
          "slug": "60"
        }
      ]
    },
    "typography": {
        "fluid": true,
        "fontFamilies": [
            {
                "fontFamily": "'Playfair Display', serif",
                "name": "Playfair Display (Luxe)",
            "slug": "heading-font",
            "fontFace": [
              {
                "fontFamily": "Playfair Display",
                "fontStyle": "normal",
                "fontWeight": "700",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/playfair-display-700-latin.woff2"
                ]
              }
            ]
            },
            {
                "fontFamily": "Inter, sans-serif",
                "name": "Inter (Moderne)",
            "slug": "body-font",
            "fontFace": [
              {
                "fontFamily": "Inter",
                "fontStyle": "normal",
                "fontWeight": "400",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/inter-400-latin.woff2"
                ]
              },
              {
                "fontFamily": "Inter",
                "fontStyle": "normal",
                "fontWeight": "700",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/inter-700-latin.woff2"
                ]
              }
            ]
            }
        ],
        "fontSizes": [
            {
                "name": "Small",
            "size": "clamp(0.95rem, 0.9rem + 0.2vw, 1.05rem)",
                "slug": "small"
            },
            {
                "name": "Medium",
            "size": "clamp(1.05rem, 1rem + 0.35vw, 1.2rem)",
                "slug": "medium"
            },
            {
                "name": "Large",
                "size": "clamp(1.75rem, 3vw, 2.25rem)",
                "slug": "large"
            },
            {
                "name": "Extra Large",
                "size": "clamp(2.5rem, 5vw, 4rem)",
                "slug": "x-large"
            }
        ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "spacing": {
      "blockGap": "1.5rem",
      "padding": {
        "left": "clamp(1rem, 3vw, 2rem)",
        "right": "clamp(1rem, 3vw, 2rem)"
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body-font)",
      "lineHeight": "1.6"
    },
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "#2A2A2A"
    },
    "elements": {
      "heading": {
        "color": "var(--wp--preset--color--contrast)",
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading-font)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "link": {
        "color": "var(--wp--preset--color--primary)"
      }
    }
  }
}
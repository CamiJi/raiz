{
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "base", "color": "#F2E8DC", "name": "Fond (Sable)" },
        { "slug": "contrast", "color": "#590902", "name": "Titres (Profond)" },
        { "slug": "primary", "color": "#8C3623", "name": "Primaire (Terre)" },
        { "slug": "secondary", "color": "#BF9180", "name": "Secondaire (Doux)" },
        { "slug": "tertiary", "color": "#8C2E26", "name": "Accent (Brique)" }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "serif",
          "name": "Serif (Élégance)",
          "slug": "serif"
        },
        {
          "fontFamily": "sans-serif",
          "name": "Sans (Moderne)",
          "slug": "sans-serif"
        }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "#2A2A2A"
    },
    "elements": {
      "heading": {
        "color": "var(--wp--preset--color--contrast)",
        "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" }
      },
      "link": {
        "color": "var(--wp--preset--color--primary)"
      }
    }
  }
}